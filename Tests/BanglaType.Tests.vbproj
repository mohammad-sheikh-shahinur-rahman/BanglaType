<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Standalone test project for BanglaType's deterministic, self-contained
    converters. It is intentionally NOT part of BanglaType.sln so the main build
    and the NuGet-publish workflow are unaffected.

    The source under test is compiled in via <Compile Link> rather than a project
    reference, so the tests build without the WinForms executable.

    Run with:  dotnet test Tests/BanglaType.Tests.vbproj
  -->

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <RootNamespace>BanglaType.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <OptionStrict>Off</OptionStrict>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="MSTest.TestFramework" Version="3.6.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.6.1" />
  </ItemGroup>

  <!-- Source under test (self-contained module, no external dependencies). -->
  <ItemGroup>
    <Compile Include="..\BijoyConverter.vb" Link="src\BijoyConverter.vb" />
  </ItemGroup>

</Project>
